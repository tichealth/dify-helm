# Production Environment Configuration
# Copy to terraform.tfvars and fill in your values. Do not commit terraform.tfvars.
#
# Secrets (required for Terraform + deploy.sh/Helm): set these in terraform.tfvars or export TF_VAR_*
#   - postgresql_password   → Azure Postgres + Helm externalPostgres.password
#   - dify_secret_key      → Helm global.appSecretKey
#   - redis_password       → Helm redis.auth.password
#   - qdrant_api_key       → Helm externalQdrant.apiKey
#   - azure_blob_account_key (if using blob for state/Dify) → backend + Dify storage

project_name = "dify-prod"
location     = "australiaeast"  # Sydney, Australia

# Optional: use existing RG by name, else leave blank
resource_group_name = ""

# AKS
node_count         = 3  # HA configuration
vm_size            = "Standard_D4s_v5"

# No Spot pool in prod by default (for stability)
enable_spot_node_pool = false

# Azure Blob Storage (secrets: set in terraform.tfvars or TF_VAR_*)
azure_blob_account_name   = "REPLACE_WITH_YOUR_STORAGE_ACCOUNT"
azure_blob_account_key    = "REPLACE_WITH_YOUR_STORAGE_KEY"
azure_blob_container_name = "dify-data"
azure_blob_account_url    = "https://REPLACE_WITH_YOUR_STORAGE_ACCOUNT.blob.core.windows.net"

# Dify app secret (deploy.sh passes to Helm global.appSecretKey)
dify_secret_key    = "REPLACE_WITH_SECURE_RANDOM_STRING"
dify_init_password = ""

# PostgreSQL - Azure Flexible Server (postgresql_password used by Terraform + deploy.sh → Helm)
use_azure_postgres = true
postgresql_username = "difyadmin"
postgresql_password = "REPLACE_WITH_SECURE_PASSWORD"
postgresql_database = "dify"
postgres_version = "16"
postgres_sku_name = "GP_Standard_D2ds_v5"  # General Purpose, 2 vCore, 8GB RAM
postgres_storage_mb   = 131072   # 128GB
postgres_storage_tier = "P15"    # Optional: e.g. P4, P6, P10, P15, P20, P30 for IOPS; null = Azure default
postgres_public_access = true   # Consider private access in prod if needed
postgres_open_firewall_all = true   # Set false only if you add rules in Azure Portal
postgres_require_secure_transport = true

# Redis (redis_password passed to Helm by deploy.sh)
redis_password = "REPLACE_WITH_SECURE_PASSWORD"
redis_chart_version = "19.6.2"

# Qdrant (qdrant_api_key passed to Helm by deploy.sh)
qdrant_api_key = "REPLACE_WITH_SECURE_API_KEY"
qdrant_chart_version = "1.16.3"

# Optional tags
tags = {
  env     = "prod"
  project = "dify"
  managed = "terraform"
}
